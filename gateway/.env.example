# HTTP
HTTP_ADDR=:8080
SHUTDOWN_TIMEOUT=15s

# gRPC backend (the service this gateway reverse-proxies to)
GRPC_BACKEND_ADDR=localhost:9090
GRPC_DIAL_TIMEOUT=5s

# Logging (zerolog)
LOG_LEVEL=info
LOG_PRETTY=false

# CORS — comma-separated; "*" allows all (and disables credentials)
CORS_ALLOWED_ORIGINS=*

# Auth — set AUTH_ENABLED=true and one of AUTH_JWT_KEY or AUTH_API_URL
AUTH_ENABLED=false
AUTH_JWT_KEY=
AUTH_API_URL=
AUTH_API_TIMEOUT=3s

# Swagger UI at /docs/, spec served at /openapi.json
SWAGGER_ENABLED=true
SWAGGER_SPEC=docs/openapi.json
